{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9001
    },
    "functions": {
      "port": 5002
    },
    "firestore": {
      "port": 8001
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "port": 4444,
      "enabled": true
    }
  }
}
